{
  "name": "website",
  "type": "module",
  "version": "1.0.2",
  "scripts": {
    "dev": "node scripts/generate-gallery-inventory.js && astro dev",
    "build": "node scripts/generate-gallery-inventory.js && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "npm run build && wrangler deploy -c wrangler.jsonc",
    "version:patch": "npm version patch --no-git-tag-version",
    "cf:dev": "npm run build && wrangler dev -c wrangler.jsonc",
    "cf:deploy": "npm run version:patch && npm run build && wrangler deploy -c wrangler.jsonc",
    "secrets:set": "bash scripts/set-secrets.sh",
    "secrets:list": "bash scripts/list-secrets.sh"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/mdx": "^5.0.3",
    "@aws-sdk/client-s3": "^3.1022.0",
    "@aws-sdk/s3-request-presigner": "^3.1022.0",
    "astro": "^6.1.3",
    "bootstrap": "^5.3.8",
    "dotenv": "^17.4.0"
  },
  "overrides": {
    "wrangler": "^4.80.0",
    "miniflare": "^4.20260320.0",
    "undici": "^7.24.0",
    "mdast-util-to-hast": "^13.2.1",
    "fast-xml-parser": "^5.5.6",
    "picomatch": "^2.3.2",
    "smol-toml": "^1.6.1",
    "svgo": "^4.0.1",
    "h3": "^1.15.9",
    "devalue": "^5.6.4"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.12",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "wrangler": "^4.80.0"
  }
}
